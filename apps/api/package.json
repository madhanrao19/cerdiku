{
  "name": "@kpm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma": "prisma",
    "db:push": "prisma db push --skip-generate && prisma generate",
    "db:vector": "node ./scripts/apply-vector.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/helmet": "^11.1.1",
    "@kpm/ai": "workspace:*",
    "@kpm/config": "workspace:*",
    "@kpm/observability": "workspace:*",
    "@kpm/types": "workspace:*",
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.3.10",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.18.0",
    "argon2": "^0.40.3",
    "fastify": "^4.28.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/testing": "^10.3.10",
    "@swc/core": "^1.7.10",
    "@types/node": "^20.14.14",
    "prisma": "^5.18.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.0.5"
  }
}
