# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
NODE_ENV=development
DATABASE_URL=postgresql://kpm:kpm@localhost:5432/kpm?schema=public
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Web / API URLs
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
SESSION_COOKIE_DOMAIN=localhost

# ---------------------------------------------------------------------------
# Object storage (S3-compatible; MinIO in dev, Azure Blob in prod)
# ---------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kpm-media
AZURE_STORAGE_CONNECTION_STRING=

# ---------------------------------------------------------------------------
# AI providers (provider-agnostic adapter selects via AI_PROVIDER)
# ---------------------------------------------------------------------------
AI_PROVIDER=anthropic
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Payments (adapter selects via PAYMENT_PROVIDER: billplz | curlec | stripe)
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=billplz
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
CURLEC_KEY_ID=
CURLEC_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_FROM=no-reply@cerdiku.local
SMTP_URL=smtp://localhost:1025

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
